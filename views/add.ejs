<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header class="header">
    <div>
      <h1>Add GPU</h1>
      <p>Enter the GPU's expected PRL earned per day and power information.</p>
    </div>
    <nav>
      <a href="/">Dashboard</a>
      <a href="/gpus">Saved GPUs</a>
      <a href="/add">Add GPU</a>
    </nav>
  </header>

  <main class="container narrow">
    <section class="card">
      <% if (error) { %>
        <p class="error"><%= error %></p>
      <% } %>

      <form method="POST" action="/add" class="form">
        <label>GPU Name</label>
        <input name="name" value="<%= formData.name || '' %>" placeholder="Example: RTX 5090">

        <label>Hashrate (TH/s)</label>
        <input name="hashrate" type="number" step="0.01" value="<%= formData.hashrate || '' %>" placeholder="Example: 309">

        <label>Power Draw (Watts)</label>
        <input name="watts" type="number" step="1" value="<%= formData.watts || '' %>" placeholder="Example: 450">

        <label>Electricity Cost ($/kWh)</label>
        <input name="powerCost" type="number" step="0.001" value="<%= formData.powerCost || '0.11' %>" placeholder="Example: 0.11">

        <label>Estimated PRL Earned Per Day</label>
        <input name="dailyPrl" type="number" step="0.0001" value="<%= formData.dailyPrl || '' %>" placeholder="Example: 15">

        <label>Notes</label>
        <textarea name="notes" rows="4" placeholder="Example: Main mining card, undervolted, basement rig"><%= formData.notes || '' %></textarea>

        <button type="submit">Save GPU</button>
      </form>
    </section>
  </main>
</body>
</html>